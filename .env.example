# ---- Application ----
APP_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=INFO
LOG_JSON=false

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
# CORS_ORIGINS MUST be single-quoted JSON (pydantic-settings parses it as JSON)
CORS_ORIGINS='["http://localhost:5173"]'
RATE_LIMIT_PER_MINUTE=60

# ---- LLM (Anthropic public API by default) ----
PRIMARY_MODEL=deepseek-v4-pro
FALLBACK_MODEL=deepseek-v4-pro
# Leave BASE_URL empty to use the default Anthropic endpoint (https://api.anthropic.com)
# For an enterprise gateway set e.g. https://genai-api.example.com
LLM_BASE_URL=https://api.deepseek.com/anthropic
MODEL_PROVIDER=deepseek
LLM_API_KEY=
LLM_MAX_TOKENS=4096
LLM_REQUESTS_PER_SECOND=200
# Optional: path to a custom CA bundle (enterprise SSL). Leave empty for public.
SSL_CERT_FILE=

# ---- GitHub (public api.github.com by default) ----
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_WEBHOOK_SECRET=
# Optional custom CA bundle for GitHub Enterprise. Leave empty for public.
GITHUB_CA_BUNDLE=

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ---- ChromaDB ----
# mode: embedded (PersistentClient, no server) | http (external server)
CHROMADB_MODE=embedded
CHROMADB_HOST=localhost
CHROMADB_PORT=8001
CHROMADB_PERSIST_DIR=.chroma
CHROMADB_COLLECTION=owasp_knowledge

# ---- LangFuse (optional observability) ----
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ---- Worker ----
WORKER_MAX_JOBS=5
WORKER_JOB_TIMEOUT=600
